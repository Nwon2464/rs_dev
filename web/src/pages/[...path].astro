---
import { App } from "../main";
import {
  SEO_ROUTES,
  translatedRoute,
  type SeoRoute,
} from "../seo/routes";
import { loadLandingContent } from "../seo/landingContent";

export function getStaticPaths() {
  return SEO_ROUTES.map((route) => ({
    params: { path: route.path },
    props: { route },
  }));
}

const { route } = Astro.props as { route: SeoRoute };
const translated = translatedRoute(route);
const canonical = new URL(route.publicPath, Astro.site);
const alternate = new URL(translated.publicPath, Astro.site);
const japanese = route.language === "ja" ? canonical : alternate;
const landing = await loadLandingContent(route);
const labels = route.language === "ja"
  ? {
      aria: "データと機能の案内",
      basis: "日本クライアント基準",
      updated: "最終データ更新",
      examples: "代表オプション",
    }
  : {
      aria: "데이터 및 기능 안내",
      basis: "일본 클라이언트 기준",
      updated: "마지막 데이터 갱신",
      examples: "대표 옵션",
    };
---

<!doctype html>
<html lang={route.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{route.title}</title>
    <meta name="description" content={route.description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={route.language} href={canonical} />
    <link
      rel="alternate"
      hreflang={translated.language}
      href={alternate}
    />
    <link rel="alternate" hreflang="x-default" href={japanese} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={route.title} />
    <meta property="og:description" content={route.description} />
    <meta property="og:url" content={canonical} />
    <meta
      property="og:locale"
      content={route.language === "ja" ? "ja_JP" : "ko_KR"}
    />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <script is:inline>
      try {
        document.documentElement.dataset.theme =
          localStorage.getItem("redstone-ui-theme") === "light"
            ? "light"
            : "dark";
      } catch (_) {}
    </script>
  </head>
  <body>
    <aside class="landing-summary" aria-label={labels.aria}>
      <p>
        <span>{labels.basis}</span>
        <span aria-hidden="true">·</span>
        <span>{labels.updated} <time datetime={landing.updatedDate}>{landing.formattedDate}</time></span>
      </p>
      <p>
        <span>{route.featureSummary}</span>
        {landing.representativeOptions.length > 0 && (
          <>
            <span aria-hidden="true">·</span>
            <strong>{labels.examples}</strong>
            <span>{landing.representativeOptions.join(" · ")}</span>
          </>
        )}
      </p>
    </aside>
    <App
      client:load
      initialView={route.view}
      initialMode={route.mode}
      initialLanguage={route.language}
      staticTitle={route.heading}
      staticDescription={route.description}
    />
  </body>
</html>

<style is:global>
  .landing-summary {
    box-sizing: border-box;
    margin: 0;
    padding: 0.45rem max(1rem, calc((100% - 1460px) / 2));
    border-bottom: 1px solid var(--line, #293144);
    color: var(--muted, #aab1c2);
    background: var(--panel, #151a25);
    font-size: 0.78rem;
  }
  .landing-summary p {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.45rem;
    margin: 0;
  }
  .landing-summary p + p {
    margin-top: 0.15rem;
  }
  .landing-summary strong {
    color: inherit;
  }
</style>
